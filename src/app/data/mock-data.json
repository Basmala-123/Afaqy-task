  "customCharts": [
    {
      "id": "chart-temp",
      "name": "Temperature Zones",
      "sensorType": "temperature",
      "roomIds": [
        "r-101","r-102","r-103","r-104","r-105",
        "r-201","r-202","r-203","r-204","r-205",
        "r-301","r-302","r-303","r-304","r-305",
        "r-401","r-402","r-403","r-404","r-405"
      ],
      "ranges": [
        { "name": "Cold",   "from": 0,  "to": 18, "color": "#7DD3FC" },
        { "name": "Normal", "from": 18, "to": 26, "color": "#4ADE80" },
        { "name": "Hot",    "from": 26, "to": 60, "color": "#FB923C" }
      ],
      "order": 0
    },
    {
      "id": "chart-hum",
      "name": "Humidity Levels",
      "sensorType": "humidity",
      "roomIds": [
        "r-101","r-102","r-103","r-104","r-105",
        "r-201","r-202","r-203","r-204","r-205",
        "r-301","r-302","r-303","r-304","r-305",
        "r-401","r-402","r-403","r-404","r-405"
      ],
      "ranges": [
        { "name": "Dry",     "from": 0,  "to": 30,  "color": "#C7D2FE" },
        { "name": "Optimal", "from": 30, "to": 70,  "color": "#818CF8" },
        { "name": "Humid",   "from": 70, "to": 100, "color": "#3730A3" }
      ],
      "order": 1
    },
    {
      "id": "chart-co2",
      "name": "CO₂ Monitor",
      "sensorType": "co2",
      "roomIds": [
        "r-201","r-202","r-203","r-204","r-205",
        "r-301","r-302","r-303","r-304","r-305",
        "r-401","r-402","r-403","r-404","r-405"
      ],
      "ranges": [
        { "name": "Safe",     "from": 0,    "to": 800,  "color": "#86EFAC" },
        { "name": "Moderate", "from": 800,  "to": 1500, "color": "#FCD34D" },
        { "name": "Danger",   "from": 1500, "to": 5000, "color": "#F87171" }
      ],
      "order": 2
    }
  ],

  "chartOrder": ["chart-temp", "chart-hum", "chart-co2"],

  "sensorBounds": {
    "temperature": { "min": 12,  "max": 35,   "unit": "°C"  },
    "humidity":    { "min": 20,  "max": 85,   "unit": "%"   },
    "co2":         { "min": 350, "max": 2000, "unit": "ppm" }
  }
